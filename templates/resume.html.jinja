<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resume</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <header class="resume-header">
        <div class="left">
            <h1>{{ about.name }}</h1>
            {% if about.website %}
            <p><a href="{{ about.website }}">{{ about.website }}</a></p>
            {% endif %}
        </div>

        <div class="right">
            <p>Email: <a href="mailto:{{ about.email }}">{{ about.email }}</a></p>
            <p>Mobile: <a href="tel:{{ about.mobile }}">{{ about.mobile }}</a></p>
            {% if about.github.link %}
            <p>Github: <a href="{{ about.github.link }}">{{ about.github.username }}</a></p>
            {% else %}
            <p>Github: {{ about.github.username }}</p>
            {% endif %}
        </div>
    </header>

    {% include "sections/about.html.jinja" %}

    {% include "sections/education.html.jinja" %}

    {% include "sections/experience.html.jinja" %}

    {% include "sections/publications.html.jinja" %}

    {% include "sections/accomplishments.html.jinja" %}

    {% include "sections/projects.html.jinja" %}
</body>

</html>